<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>LSUIElement</key>
	<true/>
	<!-- MARK: - Skilly — Sparkle auto-update removed for open-source.
	     The SUFeedURL pointed to the original Clicky author's repo.
	     Forks should add their own Sparkle configuration if desired. -->
	<key>VoiceTranscriptionProvider</key>
	<string>assemblyai</string>
	<key>NSMicrophoneUsageDescription</key>
	<string>Skilly uses your microphone so you can talk to it</string>
	<key>NSScreenCaptureUsageDescription</key>
	<string>Skilly needs screen recording access to see your screen and help you learn.</string>
	<key>NSSpeechRecognitionUsageDescription</key>
	<string>Skilly uses speech recognition to transcribe your voice when you talk to it</string>
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLName</key>
			<string>app.tryskilly.skilly</string>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>skilly</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
