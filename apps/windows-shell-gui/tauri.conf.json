{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Skilly",
  "version": "0.1.0",
  "identifier": "app.tryskilly.skilly",
  "build": {
    "frontendDist": "dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Skilly",
        "width": 360,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "icon": []
  }
}
