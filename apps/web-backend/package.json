{
  "name": "@skilly/web-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Multi-tenant control plane for the Skilly web SDK — tenant keys, origin allowlist, ephemeral token minting, SKILL.md serving, usage metering.",
  "type": "module",
  "scripts": {
    "dev": "next dev -p 4310",
    "build": "next build",
    "start": "next start -p 4310",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "bun src/db/migrate.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "smoke": "bun run scripts/production-smoke.ts",
    "test:functional": "bun run scripts/functional-test.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:report": "playwright show-report"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.18.0",
    "next": "^15.1.0",
    "pg": "^8.13.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.11.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-types": "^1.2.0",
    "drizzle-kit": "^0.31.10",
    "postcss": "^8.4.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0"
  }
}
