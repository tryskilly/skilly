# Skilly Studio / web-backend environment reference.
# Copy to .env.local for local development. Do not put real secrets in this file.

# Core runtime
OPENAI_API_KEY=

# Database
# POSTGRES_URL takes precedence over DATABASE_URL when both are present.
POSTGRES_URL=
DATABASE_URL=
SKILLY_TENANT_ID=

# Dashboard auth / sessions
WORKOS_CLIENT_ID=
WORKOS_API_KEY=
WORKOS_DASHBOARD_REDIRECT_URI=http://localhost:4310/api/auth/workos/callback
SKILLY_DASHBOARD_SESSION_SECRET=
SKILLY_DASHBOARD_PASSWORD=
SKILLY_DASHBOARD_ROLE=super_admin
SKILLY_DASHBOARD_BOOTSTRAP_WORKOS=false

# Temporary setup / diagnostics. Keep disabled in normal production runtime.
SKILLY_DB_SETUP_ENABLED=false
SKILLY_READINESS_DEBUG=false

# Polar billing
POLAR_ACCESS_TOKEN=
# Backward-compatible Starter fallback; prefer the explicit plan IDs below.
POLAR_PRODUCT_ID=
POLAR_BUILDER_STARTER_PRODUCT_ID=
POLAR_BUILDER_STUDIO_PRODUCT_ID=
POLAR_BUILDER_SCALE_PRODUCT_ID=
POLAR_WEBHOOK_SECRET=
# Backward-compatible Starter fallback; prefer the explicit plan caps below.
POLAR_PLAN_CAP_SECONDS=24000
POLAR_BUILDER_STARTER_CAP_SECONDS=24000
POLAR_BUILDER_STUDIO_CAP_SECONDS=90000
POLAR_BUILDER_SCALE_CAP_SECONDS=300000
POLAR_API_BASE=https://api.polar.sh

# Product analytics
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
POSTHOG_PROJECT_API_KEY=
POSTHOG_HOST=https://us.i.posthog.com
NEXT_PUBLIC_GA_MEASUREMENT_ID=
GA_MEASUREMENT_ID=
GA_API_SECRET=

# Netlify build/runtime
NODE_VERSION=20
NETLIFY_NEXT_SKEW_PROTECTION=true
